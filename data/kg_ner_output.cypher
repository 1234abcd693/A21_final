MERGE (st_ST_DEEP_9157)-[:NEXT_STEP]->(st_ST_DEEP_9158)
MERGE (st_ST_DEEP_9159:Step {uid: 'ST_DEEP_9159'}) SET st_ST_DEEP_9159.name='用短路侦察器检查：将短路侦察器放在定子铁心槽口后接通交流电源，沿着铁心内圆逐槽移动，当它经过短路绕组时，电流表会指示较大的电流；也可用0.5mm厚的钢片或旧锯条放在被测绕组的另一线圈边所在的槽口上面，如果被测绕组短路，则钢片或旧锯条会产生振动', st_ST_DEEP_9159.created_at=timestamp()
