MERGE (st_ST_DEEP_9174)-[:REQUIRES_TOOL]->(t_T_DEEP_11035)
MERGE (t_T_DEEP_11036:Tool {uid: 'T_DEEP_11036'}) SET t_T_DEEP_11036.name='车床', t_T_DEEP_11036.created_at=timestamp()
MERGE (st_ST_DEEP_9174)-[:REQUIRES_TOOL]->(t_T_DEEP_11036)
