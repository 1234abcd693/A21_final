MERGE (st_ST_DEEP_9146:Step {uid: 'ST_DEEP_9146'}) SET st_ST_DEEP_9146.name='若只有当转速下降到一定程度时噪声才消灭，而且噪声大小随转速减小而明显减小，说明是由机械部分引起的机械噪声', st_ST_DEEP_9146.created_at=timestamp()
MERGE (st_ST_DEEP_9145)-[:NEXT_STEP]->(st_ST_DEEP_9146)
MERGE (st_ST_DEEP_9147:Step {uid: 'ST_DEEP_9147'}) SET st_ST_DEEP_9147.name='若切除电源，噪声只是减弱，说明既有电磁噪声，又有机械噪声', st_ST_DEEP_9147.created_at=timestamp()
MERGE (st_ST_DEEP_9146)-[:NEXT_STEP]->(st_ST_DEEP_9147)
MERGE (st_ST_DEEP_9148:Step {uid: 'ST_DEEP_9148'}) SET st_ST_DEEP_9148.name='根据判断结果再进一步检查', st_ST_DEEP_9148.created_at=timestamp()
MERGE (st_ST_DEEP_9147)-[:NEXT_STEP]->(st_ST_DEEP_9148)

