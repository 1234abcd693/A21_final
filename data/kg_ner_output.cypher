MERGE (s_S_DEEP_2053)-[:CAUSED_BY {priority: 1}]->(c_C_DEEP_8159)
MERGE (c_C_DEEP_8160:Cause {uid: 'C_DEEP_8160'}) SET c_C_DEEP_8160.name='绕组内部个别线圈或极相组接错或嵌反', c_C_DEEP_8160.check_method='test', c_C_DEEP_8160.created_at=timestamp()
MERGE (s_S_DEEP_2053)-[:CAUSED_BY {priority: 2}]->(c_C_DEEP_8160)
MERGE (st_ST_DEEP_9165:Step {uid: 'ST_DEEP_9165'}) SET st_ST_DEEP_9165.name='交流感应法：将任意两相定子绕组串联，连接之后再接一低压(36V)灯泡，而另一相绕组接低压(36V)交流电源，如果灯泡亮，说明串联的两相绕组是首尾相连；如果灯泡不亮，则说明两相绕组是同名端相连', st_ST_DEEP_9165.created_at=timestamp()
MERGE (c_C_DEEP_8159)-[:FIXED_BY]->(st_ST_DEEP_9165)
MERGE (st_ST_DEEP_9166:Step {uid: 'ST_DEEP_9166'}) SET st_ST_DEEP_9166.name='直流感应法：在测出每一相绕组的端头之后，按图5-13进行连接，电源用两节电池，电流表用直流毫安表。当开关K闭合一瞬间，如果电流表指针正向偏转，则表明连接电池正极的接线与连接电流表正极的接线的端头是异名端，反之为同名端', st_ST_DEEP_9166.created_at=timestamp()
MERGE (st_ST_DEEP_9165)-[:NEXT_STEP]->(st_ST_DEEP_9166)
MERGE (st_ST_DEEP_9167:Step {uid: 'ST_DEEP_9167'}) SET st_ST_DEEP_9167.name='剩磁感应法：三相异步电动机的绕组按图5-14接线。用手转动转子，当毫安表指针基本不动时，说明各相绕组假定的首尾端正确。若指针摆动很大，则说明其中一相首端接错，应调换一相绕组首尾端再试', st_ST_DEEP_9167.created_at=timestamp()
MERGE (st_ST_DEEP_9166)-[:NEXT_STEP]->(st_ST_DEEP_9167)
MERGE (st_ST_DEEP_9168:Step {uid: 'ST_DEEP_9168'}) SET st_ST_DEEP_9168.name='旋转磁场法：三相自耦调压器输出三相对称的低压交流电源给三相异步电动机的绕组，若绕组首尾端接线正确就会产生一个均匀的旋转磁场，用一指南针或短路环位于定子内腔中央就会旋转。若电动机转速太高或太低甚至不转，说明三相绕组首尾接线有误，应依次调换直到转动正常为止', st_ST_DEEP_9168.created_at=timestamp()
MERGE (st_ST_DEEP_9167)-[:NEXT_STEP]->(st_ST_DEEP_9168)
MERGE (st_ST_DEEP_9169:Step {uid: 'ST_DEEP_9169'}) SET st_ST_DEEP_9169.name='将低压直流电通入某相绕组，用指南针沿着定子铁心内圆移动，逐槽检查，如果指南针经过各极组时，指南针的方向交替变化，表示接线正确；如果经过相邻极相组时指南针的指向不变，则表示极相组接反。如果一个极相组中个别线圈嵌反，这时在极相内指南针指向就会交替变化', st_ST_DEEP_9169.created_at=timestamp()
MERGE (st_ST_DEEP_9168)-[:NEXT_STEP]->(st_ST_DEEP_9169)
MERGE (t_T_DEEP_11028:Tool {uid: 'T_DEEP_11028'}) SET t_T_DEEP_11028.name='灯泡', t_T_DEEP_11028.created_at=timestamp()
MERGE (st_ST_DEEP_9169)-[:REQUIRES_TOOL]->(t_T_DEEP_11028)
MERGE (t_T_DEEP_11029:Tool {uid: 'T_DEEP_11029'}) SET t_T_DEEP_11029.name='电池', t_T_DEEP_11029.created_at=timestamp()
MERGE (st_ST_DEEP_9169)-[:REQUIRES_TOOL]->(t_T_DEEP_11029)
MERGE (t_T_DEEP_11030:Tool {uid: 'T_DEEP_11030'}) SET t_T_DEEP_11030.name='直流毫安表', t_T_DEEP_11030.created_at=timestamp()
MERGE (st_ST_DEEP_9169)-[:REQUIRES_TOOL]->(t_T_DEEP_11030)
MERGE (t_T_DEEP_11031:Tool {uid: 'T_DEEP_11031'}) SET t_T_DEEP_11031.name='指南针', t_T_DEEP_11031.created_at=timestamp()
MERGE (st_ST_DEEP_9169)-[:REQUIRES_TOOL]->(t_T_DEEP_11031)
MERGE (t_T_DEEP_11032:Tool {uid: 'T_DEEP_11032'}) SET t_T_DEEP_11032.name='自耦变压器', t_T_DEEP_11032.created_at=timestamp()
MERGE (st_ST_DEEP_9169)-[:REQUIRES_TOOL]->(t_T_DEEP_11032)

// --- 笼型异步电动机: 笼型转子断笼 ---
MERGE (s_S_DEEP_2054:Symptom {uid: 'S_DEEP_2054'}) SET s_S_DEEP_2054.name='笼型转子断笼', s_S_DEEP_2054.primary_features=["空转但起动转矩和额定转矩均降低很多", "三相绕组电流表指针来回摆动", "异常噪声"], s_S_DEEP_2054.source_doc='船舶电气设备维护与修理', s_S_DEEP_2054.source_page='第五章第三节', s_S_DEEP_2054.created_at=timestamp()
MERGE (c_C_DEEP_8161:Cause {uid: 'C_DEEP_8161'}) SET c_C_DEEP_8161.name='铸铝质量不好', c_C_DEEP_8161.check_method='inspect', c_C_DEEP_8161.created_at=timestamp()
MERGE (s_S_DEEP_2054)-[:CAUSED_BY {priority: 1}]->(c_C_DEEP_8161)
MERGE (c_C_DEEP_8162:Cause {uid: 'C_DEEP_8162'}) SET c_C_DEEP_8162.name='使用不当，如经常正反转起动或过载和冲击负载', c_C_DEEP_8162.check_method='inspect', c_C_DEEP_8162.created_at=timestamp()
MERGE (s_S_DEEP_2054)-[:CAUSED_BY {priority: 2}]->(c_C_DEEP_8162)
MERGE (st_ST_DEEP_9170:Step {uid: 'ST_DEEP_9170'}) SET st_ST_DEEP_9170.name='将转子取出检查，先目测，若端环开裂，一般可以看出；若断条严重，运行时间长，在断条槽口处可能会出现小黑洞', st_ST_DEEP_9170.created_at=timestamp()
MERGE (c_C_DEEP_8161)-[:FIXED_BY]->(st_ST_DEEP_9170)
MERGE (st_ST_DEEP_9171:Step {uid: 'ST_DEEP_9171'}) SET st_ST_DEEP_9171.name='若目测不易发现，可用短路侦察器检查，逐步转动转子，当被短路侦察器磁通包围的笼条完好时，短路侦察器电流表的读数大，如果该处笼条有断裂，则电流表读数变小', st_ST_DEEP_9171.created_at=timestamp()
MERGE (st_ST_DEEP_9170)-[:NEXT_STEP]->(st_ST_DEEP_9171)
MERGE (st_ST_DEEP_9172:Step {uid: 'ST_DEEP_9172'}) SET st_ST_DEEP_9172.name='焊接法：将导条或端环的裂口扩大，然后把转子加热到左右,再用锡(63%)、锌(33%)和铝(4%)组成的钎料气焊补焊', st_ST_DEEP_9172.created_at=timestamp()
MERGE (st_ST_DEEP_9171)-[:NEXT_STEP]->(st_ST_DEEP_9172)
MERGE (st_ST_DEEP_9173:Step {uid: 'ST_DEEP_9173'}) SET st_ST_DEEP_9173.name='冷接法：在裂口处用一只与槽宽相近的钻头钻孔并攻螺纹，然后拧上一个铝螺钉，再用车床或铲刀除掉螺钉的多余部分', st_ST_DEEP_9173.created_at=timestamp()
MERGE (st_ST_DEEP_9172)-[:NEXT_STEP]->(st_ST_DEEP_9173)
MERGE (st_ST_DEEP_9174:Step {uid: 'ST_DEEP_9174'}) SET st_ST_DEEP_9174.name='换条法：用车床车去原有的端环，用夹具夹住转子铁心，浸入浓度为60%的工业烧碱液中6、7h，便可以将铝条腐蚀掉；铝熔化后的转子立即用水冲洗，再投入0.25%浓度的冰醋酸溶液中煮沸1~2h后取出烘干；也可将转子直接加热到700℃左右，将铝条全部熔掉并清理干净；将截面积等于转子槽形面积70%的铜条插入槽内，铜条两端伸出槽口20~30mm，再将车好的端环按转子槽口位置对应钻孔，套在铜条上，铜条与端环之间用磷铜焊牢', st_ST_DEEP_9174.created_at=timestamp()
MERGE (st_ST_DEEP_9173)-[:NEXT_STEP]->(st_ST_DEEP_9174)
MERGE (t_T_DEEP_11033:Tool {uid: 'T_DEEP_11033'}) SET t_T_DEEP_11033.name='短路侦察器', t_T_DEEP_11033.created_at=timestamp()
MERGE (st_ST_DEEP_9174)-[:REQUIRES_TOOL]->(t_T_DEEP_11033)
MERGE (t_T_DEEP_11034:Tool {uid: 'T_DEEP_11034'}) SET t_T_DEEP_11034.name='电流表', t_T_DEEP_11034.created_at=timestamp()
MERGE (st_ST_DEEP_9174)-[:REQUIRES_TOOL]->(t_T_DEEP_11034)
