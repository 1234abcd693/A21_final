// --- 三相异步电动机: 绕组接线错误与嵌反 ---
MERGE (s_S_DEEP_2053:Symptom {uid: 'S_DEEP_2053'}) SET s_S_DEEP_2053.name='绕组接线错误与嵌反', s_S_DEEP_2053.primary_features=["不能正常运行", "剧烈振动", "噪声异常", "三相电流严重不平衡", "温度升高", "转速降低", "不转"], s_S_DEEP_2053.source_doc='船舶电气设备维护与修理', s_S_DEEP_2053.source_page='第五章第三节', s_S_DEEP_2053.created_at=timestamp()
