MERGE (st_ST_DEEP_9155)-[:REQUIRES_TOOL]->(t_T_DEEP_11016)
MERGE (t_T_DEEP_11017:Tool {uid: 'T_DEEP_11017'}) SET t_T_DEEP_11017.name='电桥', t_T_DEEP_11017.created_at=timestamp()
MERGE (st_ST_DEEP_9155)-[:REQUIRES_TOOL]->(t_T_DEEP_11017)
MERGE (t_T_DEEP_11018:Tool {uid: 'T_DEEP_11018'}) SET t_T_DEEP_11018.name='自耦变压器', t_T_DEEP_11018.created_at=timestamp()
MERGE (st_ST_DEEP_9155)-[:REQUIRES_TOOL]->(t_T_DEEP_11018)

