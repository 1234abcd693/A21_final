MERGE (st_ST_DEEP_9152:Step {uid: 'ST_DEEP_9152'}) SET st_ST_DEEP_9152.name='电流平衡法：对于星形联结的电动机，将三相绕组并联后用自耦变压器提供低电压、大电流的交流电，然后用钳形表测各相支路的电流，如果三相电流相差5%以上时，电流小的一相为断路相', st_ST_DEEP_9152.created_at=timestamp()
MERGE (c_C_DEEP_8151)-[:FIXED_BY]->(st_ST_DEEP_9152)
