MERGE (st_ST_DEEP_9152)-[:NEXT_STEP]->(st_ST_DEEP_9153)
MERGE (st_ST_DEEP_9154:Step {uid: 'ST_DEEP_9154'}) SET st_ST_DEEP_9154.name='对于三角形联结的电动机，先将定子绕组的接点拆开，再逐相通入低电压的交流电，测量其电流，其中电流小的一相即为断路相', st_ST_DEEP_9154.created_at=timestamp()
MERGE (st_ST_DEEP_9153)-[:NEXT_STEP]->(st_ST_DEEP_9154)
MERGE (st_ST_DEEP_9155:Step {uid: 'ST_DEEP_9155'}) SET st_ST_DEEP_9155.name='电阻法：采用电桥测量三相绕组的电阻，若电阻值相差5%以上，电阻较大的一相绕组可能有断路故障', st_ST_DEEP_9155.created_at=timestamp()
MERGE (st_ST_DEEP_9154)-[:NEXT_STEP]->(st_ST_DEEP_9155)
