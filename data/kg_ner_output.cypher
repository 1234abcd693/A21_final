MERGE (s_S_DEEP_2050:Symptom {uid: 'S_DEEP_2050'}) SET s_S_DEEP_2050.name='绕组断路故障', s_S_DEEP_2050.primary_features=["断路"], s_S_DEEP_2050.source_doc='船舶电气设备维护与修理', s_S_DEEP_2050.source_page='第五章第三节', s_S_DEEP_2050.created_at=timestamp()
